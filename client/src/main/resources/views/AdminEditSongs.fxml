<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hitster.controllers.AdminEditSongsController">
   <children>
      <HBox spacing="30.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="100.0">
         <children>
            
            <VBox alignment="TOP_CENTER" minWidth="220.0" spacing="20.0" styleClass="admin-sidebar-box">
               <children>
                  <Button fx:id="navSongsButton" maxWidth="Infinity" mnemonicParsing="false" prefHeight="60.0" styleClass="admin-side-btn-active" text="Songs" />
                  <Button fx:id="navUsersButton" maxWidth="Infinity" mnemonicParsing="false" prefHeight="60.0" styleClass="admin-side-btn" text="Users" />
               </children>
               <padding>
                  <Insets bottom="30.0" left="15.0" right="15.0" top="30.0" />
               </padding>
            </VBox>

            <VBox spacing="25.0" HBox.hgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="admin-title" text="ADMIN: Song Editor" />
                     </children>
                  </HBox>
                  
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <TextField fx:id="searchField" prefHeight="55.0" promptText="Search Song 🔍" styleClass="search-field" HBox.hgrow="ALWAYS" />
                        <Button fx:id="addSongButton" minWidth="160.0" mnemonicParsing="false" prefHeight="55.0" styleClass="add-action-btn" text="+ Add Song" />
                        <Button fx:id="deleteSelectedButton" minWidth="180.0" mnemonicParsing="false" prefHeight="55.0" styleClass="danger-action-btn" text="🗑 Delete Selected" />
                     </children>
                  </HBox>

                  <TableView fx:id="songsTable" fixedCellSize="55.0" styleClass="admin-table" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="selectColumn" minWidth="70.0" prefWidth="-1.0" reorderable="false" sortable="false" text="Select" />
                      <TableColumn fx:id="idColumn" minWidth="60.0" prefWidth="-1.0" reorderable="false" sortable="false" text="ID" />
                      <TableColumn fx:id="titleColumn" minWidth="200.0" prefWidth="-1.0" reorderable="false" sortable="false" text="Song title" />
                      <TableColumn fx:id="artistColumn" minWidth="150.0" prefWidth="-1.0" reorderable="false" sortable="false" text="Artist" />
                      <TableColumn fx:id="yearColumn" minWidth="80.0" prefWidth="-1.0" reorderable="false" sortable="false" text="Year" />
                      <TableColumn fx:id="linkColumn" minWidth="250.0" prefWidth="-1.0" reorderable="false" sortable="false" text="Link" />
                      <TableColumn fx:id="editColumn" minWidth="80.0" prefWidth="-1.0" reorderable="false" sortable="false" text="Edit" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>

      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" style="-fx-padding: 0;" styleClass="back-button" text="←" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0" />
   </children>
</AnchorPane>
