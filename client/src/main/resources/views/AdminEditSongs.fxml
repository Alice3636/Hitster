<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hitster.controllers.AdminEditSongsController">
   <children>
      <HBox AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="100.0" style="-fx-spacing: 2em;">
         <children>
            
            <VBox alignment="TOP_CENTER" styleClass="admin-sidebar-box" style="-fx-min-width: 16em; -fx-spacing: 1.5em; -fx-padding: 2em 1em;">
               <children>
                  <Button fx:id="navSongsButton" maxWidth="Infinity" mnemonicParsing="false" styleClass="admin-side-btn-active" text="Songs" style="-fx-pref-height: 4em; -fx-font-size: 1.1em;" />
                  <Button fx:id="navUsersButton" maxWidth="Infinity" mnemonicParsing="false" styleClass="admin-side-btn" text="Users" style="-fx-pref-height: 4em; -fx-font-size: 1.1em;" />
               </children>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" style="-fx-spacing: 1.5em;">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="admin-title" text="ADMIN: Song Editor" style="-fx-font-size: 2.5em; -fx-font-weight: bold;" />
                     </children>
                  </HBox>
                  
                  <HBox alignment="CENTER_LEFT" style="-fx-spacing: 1.2em;">
                     <children>
                        <TextField fx:id="searchField" promptText="Search Song 🔍" styleClass="search-field" HBox.hgrow="ALWAYS" style="-fx-pref-height: 3.5em; -fx-font-size: 1.2em;" />
                        <Button fx:id="addSongButton" mnemonicParsing="false" styleClass="add-action-btn" text="+ Add Song" style="-fx-min-width: 10em; -fx-pref-height: 3.5em; -fx-font-size: 1.2em;" />
                        <Button fx:id="deleteSelectedButton" mnemonicParsing="false" styleClass="danger-action-btn" text="🗑 Delete Selected" style="-fx-min-width: 12em; -fx-pref-height: 3.5em; -fx-font-size: 1.2em;" />
                     </children>
                  </HBox>

                  <TableView fx:id="songsTable" styleClass="admin-table" VBox.vgrow="ALWAYS" style="-fx-fixed-cell-size: 3.5em; -fx-font-size: 1.1em;">
                    <columns>
                      <TableColumn fx:id="selectColumn" reorderable="false" sortable="false" text="Select" style="-fx-min-width: 4em;" />
                      <TableColumn fx:id="idColumn" reorderable="false" sortable="false" text="ID" style="-fx-min-width: 4em;" />
                      <TableColumn fx:id="titleColumn" reorderable="false" sortable="false" text="Song title" style="-fx-min-width: 15em;" />
                      <TableColumn fx:id="artistColumn" reorderable="false" sortable="false" text="Artist" style="-fx-min-width: 10em;" />
                      <TableColumn fx:id="yearColumn" reorderable="false" sortable="false" text="Year" style="-fx-min-width: 5em;" />
                      <TableColumn fx:id="linkColumn" reorderable="false" sortable="false" text="Link" style="-fx-min-width: 18em;" />
                      <TableColumn fx:id="editColumn" reorderable="false" sortable="false" text="Edit" style="-fx-min-width: 5em;" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>

      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" styleClass="back-button" text="←" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0" style="-fx-padding: 0; -fx-font-size: 2.5em;" />
   </children>
</AnchorPane>