<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hitster.controllers.ForgotPasswordController">
   <children>
      <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" maxWidth="750.0" spacing="40.0" styleClass="login-box">
               <children>
                  <VBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Label alignment="CENTER" styleClass="forgot-title" text="FORGOT PASSWORD" textAlignment="CENTER">
                           <font>
                              <Font size="64.0" />
                           </font>
                        </Label>
                        <Label styleClass="subtitle" text="Enter your email to receive a reset link">
                           <font>
                              <Font size="22.0" />
                           </font>
                        </Label>
                     </children>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </VBox>

                  <VBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label styleClass="field-label" text="EMAIL ADDRESS">
                           <font>
                              <Font size="22.0" />
                           </font>
                        </Label>
                        <TextField fx:id="emailField" prefHeight="55.0" styleClass="text-field">
                           <font>
                              <Font size="20.0" />
                           </font>
                        </TextField>
                     </children>
                     <padding>
                        <Insets left="50.0" right="50.0" />
                     </padding>
                  </VBox>

                  <VBox alignment="CENTER" spacing="30.0">
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                     <children>
                        <Button fx:id="resetButton" defaultButton="true" mnemonicParsing="false" onAction="#handleResetPassword" prefHeight="65.0" prefWidth="350.0" style="-fx-font-weight: bold;" styleClass="forgot-button" text="SEND RESET LINK">
                           <font>
                              <Font size="22.0" />
                           </font>
                        </Button>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="50.0" top="50.0" />
               </padding>
            </VBox>
         </children>
      </StackPane>

      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" style="-fx-padding: 0;" styleClass="back-button" text="←" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0">
         <font>
            <Font size="36.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
