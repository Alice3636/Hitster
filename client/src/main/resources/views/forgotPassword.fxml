<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hitster.controllers.ForgotPasswordController">
   <children>
      <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" styleClass="login-box" style="-fx-max-width: 48em; -fx-spacing: 2.5em; -fx-padding: 4em 3em;">
               <children>
                  <VBox alignment="CENTER" style="-fx-spacing: 0.5em; -fx-padding: 0 0 1em 0;">
                     <children>
                        <Label alignment="CENTER" styleClass="forgot-title" text="FORGOT PASSWORD" textAlignment="CENTER" style="-fx-font-size: 4em; -fx-font-weight: bold;" />
                        <Label styleClass="subtitle" text="Enter your email to receive a reset link" style="-fx-font-size: 1.5em;" />
                     </children>
                  </VBox>

                  <VBox alignment="CENTER_LEFT" style="-fx-spacing: 0.8em; -fx-padding: 0 3em;">
                     <children>
                        <Label styleClass="field-label" text="EMAIL ADDRESS" style="-fx-font-size: 1.3em;" />
                        <TextField fx:id="emailField" styleClass="text-field" style="-fx-pref-height: 3.5em; -fx-font-size: 1.25em;" />
                     </children>
                  </VBox>

                  <VBox alignment="CENTER" style="-fx-padding: 1.5em 0 0 0;">
                     <children>
                        <Button fx:id="resetButton" defaultButton="true" mnemonicParsing="false" onAction="#handleResetPassword" styleClass="forgot-button" text="SEND RESET LINK" style="-fx-font-weight: bold; -fx-pref-height: 4em; -fx-pref-width: 22em; -fx-font-size: 1.5em;" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </StackPane>

      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" styleClass="back-button" text="←" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0" style="-fx-padding: 0; -fx-font-size: 2.5em;" />
   </children>
</AnchorPane>