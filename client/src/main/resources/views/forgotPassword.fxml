<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" stylesheets="@../css/styles.css"
   xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
   fx:controller="com.hitster.controllers.ForgotPasswordController">
   <children>
      <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
         AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" maxWidth="750.0" spacing="30.0" styleClass="login-box">
               <padding>
                  <Insets bottom="50.0" top="50.0" />
               </padding>
               <children>
                  <VBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Label alignment="CENTER" styleClass="forgot-title" text="FORGOT PASSWORD"
                           textAlignment="CENTER">
                           <font>
                              <Font size="64.0" />
                           </font>
                        </Label>
                        <Label fx:id="subtitleLabel" styleClass="subtitle"
                           text="Enter your email to receive a reset link">
                           <font>
                              <Font size="22.0" />
                           </font>
                        </Label>
                     </children>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </VBox>

                  <VBox fx:id="emailStepBox" alignment="CENTER" spacing="20.0">
                     <children>
                        <VBox alignment="CENTER_LEFT" spacing="10.0">
                           <padding>
                              <Insets left="50.0" right="50.0" />
                           </padding>
                           <children>
                              <Label styleClass="field-label" text="EMAIL ADDRESS">
                                 <font>
                                    <Font size="22.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="emailField" prefHeight="55.0"
                                 styleClass="text-field">
                                 <font>
                                    <Font size="20.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>
                        <Button fx:id="resetButton" defaultButton="true" mnemonicParsing="false"
                           onAction="#handleResetPassword" prefHeight="65.0" prefWidth="350.0"
                           style="-fx-font-weight: bold;" styleClass="forgot-button"
                           text="SEND RESET LINK">
                           <font>
                              <Font size="22.0" />
                           </font>
                           <VBox.margin>
                              <Insets top="10.0" />
                           </VBox.margin>
                        </Button>
                     </children>
                  </VBox>

                  <VBox fx:id="otpStepBox" alignment="CENTER" managed="false" spacing="20.0"
                     visible="false">
                     <children>
                        <VBox alignment="CENTER_LEFT" spacing="10.0">
                           <padding>
                              <Insets left="50.0" right="50.0" />
                           </padding>
                           <children>
                              <Label styleClass="field-label" text="VERIFICATION CODE">
                                 <font>
                                    <Font size="22.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="codeField" prefHeight="55.0" styleClass="text-field"
                                 promptText="6-digit code">
                                 <font>
                                    <Font size="20.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>

                        <VBox alignment="CENTER_LEFT" spacing="10.0">
                           <padding>
                              <Insets left="50.0" right="50.0" />
                           </padding>
                           <children>
                              <Label styleClass="field-label" text="NEW PASSWORD">
                                 <font>
                                    <Font size="22.0" />
                                 </font>
                              </Label>
                              <PasswordField fx:id="newPasswordField" prefHeight="55.0"
                                 styleClass="text-field">
                                 <font>
                                    <Font size="20.0" />
                                 </font>
                              </PasswordField>
                           </children>
                        </VBox>

                        <Button fx:id="confirmResetButton" mnemonicParsing="false"
                           onAction="#handleConfirmReset" prefHeight="65.0" prefWidth="350.0"
                           style="-fx-font-weight: bold;" styleClass="forgot-button"
                           text="CONFIRM RESET">
                           <font>
                              <Font size="22.0" />
                           </font>
                           <VBox.margin>
                              <Insets top="10.0" />
                           </VBox.margin>
                        </Button>
                     </children>
                  </VBox>

               </children>
            </VBox>
         </children>
      </StackPane>

      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack"
         style="-fx-padding: 0;" styleClass="back-button" text="←" AnchorPane.leftAnchor="30.0"
         AnchorPane.topAnchor="30.0">
         <font>
            <Font size="36.0" />
         </font>
      </Button>
   </children>
</AnchorPane>