<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hitster.controllers.AdminEditAccountsController">
   <children>
      <HBox AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="100.0" style="-fx-spacing: 2em;">
         <children>
            
            <VBox alignment="TOP_CENTER" styleClass="admin-sidebar-box-accounts" style="-fx-min-width: 16em; -fx-spacing: 1.5em; -fx-padding: 2em 1em;">
               <children>
                  <Button fx:id="navSongsButton" maxWidth="Infinity" mnemonicParsing="false" styleClass="admin-side-btn-accounts" text="Songs" style="-fx-pref-height: 4em; -fx-font-size: 1.1em;" />
                  <Button fx:id="navUsersButton" maxWidth="Infinity" mnemonicParsing="false" styleClass="admin-side-btn-accounts-active" text="Users" style="-fx-pref-height: 4em; -fx-font-size: 1.1em;" />
               </children>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" style="-fx-spacing: 1.5em;">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label styleClass="admin-title-accounts" text="ADMIN: User Editor" style="-fx-font-size: 2.5em; -fx-font-weight: bold;" />
                     </children>
                  </HBox>

                  <HBox alignment="CENTER_LEFT" style="-fx-spacing: 1.5em;">
                     <children>
                        <TextField fx:id="searchField" promptText="Search User 🔍" styleClass="search-field-accounts" HBox.hgrow="ALWAYS" style="-fx-pref-height: 3.5em; -fx-font-size: 1.2em;" />
                        <Button fx:id="deleteSelectedButton" mnemonicParsing="false" styleClass="danger-action-btn" text="🗑 Delete Selected" style="-fx-min-width: 14em; -fx-pref-height: 3.5em; -fx-font-size: 1.2em;" />
                     </children>
                  </HBox>

                  <TableView fx:id="usersTable" styleClass="admin-table-accounts" VBox.vgrow="ALWAYS" style="-fx-fixed-cell-size: 3.5em; -fx-font-size: 1.1em;">
                     <columns>
                        <TableColumn fx:id="selectColumn" text="Select" style="-fx-min-width: 5em;" />
                        <TableColumn fx:id="idColumn" text="ID" style="-fx-min-width: 5em;" />
                        <TableColumn fx:id="usernameColumn" text="Username" style="-fx-min-width: 15em;" />
                        <TableColumn fx:id="emailColumn" text="Email" style="-fx-min-width: 18em;" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>

      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" styleClass="back-button" text="←" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0" style="-fx-padding: 0; -fx-font-size: 2.5em;" />
   </children>
</AnchorPane>