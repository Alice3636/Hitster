<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hitster.controllers.ProfileController">
   <children>
      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" styleClass="back-button" text="←" AnchorPane.leftAnchor="3em" AnchorPane.topAnchor="2em" style="-fx-font-size: 3em; -fx-padding: 0;" />
      
      <VBox alignment="CENTER" spacing="2em" AnchorPane.bottomAnchor="2em" AnchorPane.leftAnchor="2em" AnchorPane.rightAnchor="2em" AnchorPane.topAnchor="2em">
         <children>
            <Label styleClass="hitster-title" text="MY PROFILE" style="-fx-font-size: 4.5em; -fx-letter-spacing: 0.2em;" />

            <HBox alignment="CENTER" spacing="4em">
               <children>
                  <VBox alignment="CENTER" spacing="2em" style="-fx-pref-width: 35em;">
                     <children>
                        <VBox alignment="CENTER" spacing="1em" styleClass="desktop-panel" style="-fx-padding: 2em; -fx-pref-height: 22em;">
                           <children>
                              <HBox alignment="CENTER" spacing="1em">
                                 <children>
                                    <StackPane onMouseClicked="#handleUploadImage" styleClass="avatar-circle" style="-fx-cursor: hand; -fx-max-width: 8.5em; -fx-max-height: 8.5em; -fx-pref-width: 8.5em; -fx-pref-height: 8.5em;">
                                       <children>
                                          <ImageView fx:id="profileImageView" preserveRatio="false" fitHeight="130.0" fitWidth="130.0">
                                             <clip><Circle centerX="65.0" centerY="65.0" radius="65.0" /></clip>
                                          </ImageView>
                                       </children>
                                    </StackPane>
                                    <Button mnemonicParsing="false" onAction="#handleEditUsername" styleClass="edit-btn" text="✎">
                                       <HBox.margin><Insets top="80.0" /></HBox.margin>
                                    </Button>
                                 </children>
                              </HBox>
                              
                              <HBox alignment="CENTER" spacing="1em">
                                 <children>
                                    <Label fx:id="usernameLabel" styleClass="profile-text-main" text="User" />
                                    <Button mnemonicParsing="false" onAction="#handleEditUsername" styleClass="edit-btn" text="✎" />
                                 </children>
                              </HBox>
                              
                              <HBox alignment="CENTER" spacing="1em">
                                 <children>
                                    <Label fx:id="emailLabel" styleClass="profile-text-sub" text="User@gmail.com" />
                                    <Button mnemonicParsing="false" onAction="#handleEditEmail" styleClass="edit-btn" text="✎" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="1.5em" styleClass="desktop-panel" style="-fx-padding: 2em; -fx-pref-height: 16em;">
                           <children>
                              <Label styleClass="subtitle" text="STATISTICS" style="-fx-font-size: 2em; -fx-letter-spacing: 0.1em;" />
                              <HBox alignment="CENTER" spacing="5em">
                                 <children>
                                    <VBox alignment="CENTER" spacing="0.5em">
                                       <children>
                                          <StackPane styleClass="stat-circle" style="-fx-max-width: 6.5em; -fx-max-height: 6.5em; -fx-pref-width: 6.5em; -fx-pref-height: 6.5em;">
                                             <children><Label fx:id="totalWinsLabel" styleClass="stat-value" text="1" /></children>
                                          </StackPane>
                                          <Label styleClass="profile-text-sub" text="Total Wins" style="-fx-font-size: 1.4em;" />
                                       </children>
                                    </VBox>
                                    <VBox alignment="CENTER" spacing="0.5em">
                                       <children>
                                          <StackPane styleClass="stat-circle" style="-fx-max-width: 6.5em; -fx-max-height: 6.5em; -fx-pref-width: 6.5em; -fx-pref-height: 6.5em;">
                                             <children><Label fx:id="winRateLabel" styleClass="stat-value" text="1%" /></children>
                                          </StackPane>
                                          <Label styleClass="profile-text-sub" text="Win Rate" style="-fx-font-size: 1.4em;" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <VBox alignment="CENTER" spacing="2em" style="-fx-pref-width: 56em;">
                     <children>
                        <VBox alignment="CENTER" spacing="1em" styleClass="desktop-panel" style="-fx-padding: 1.5em; -fx-pref-height: 33em;">
                           <children>
                              <Label styleClass="subtitle" text="MATCH HISTORY" style="-fx-font-size: 2em; -fx-letter-spacing: 0.1em;" />
                              <StackPane VBox.vgrow="ALWAYS">
                                 <children>
                                    <TableView fx:id="matchHistoryTable" fixedCellSize="65.0" styleClass="glow-table">
                                      <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                      <columns>
                                         <TableColumn fx:id="opponentCol" sortable="false" style="-fx-alignment: CENTER;" text="PLAYER" />
                                         <TableColumn fx:id="dateCol" sortable="false" style="-fx-alignment: CENTER;" text="DATE" />
                                         <TableColumn fx:id="resultCol" sortable="false" style="-fx-alignment: CENTER;" text="RESULT" />
                                      </columns>
                                    </TableView>
                                    <Region maxHeight="35.0" prefHeight="35.0" StackPane.alignment="TOP_CENTER" />
                                 </children>
                              </StackPane>
                           </children>
                        </VBox>
                        
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onDeleteAccountClick" styleClass="danger-button" text="DELETE ACCOUNT" style="-fx-pref-height: 4.5em;" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>