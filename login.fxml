<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="700.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hitster.client.controllers.LoginController">
   <children>
      <Button fx:id="backButton" layoutX="20.0" layoutY="20.0" mnemonicParsing="false" onAction="#handleBack" styleClass="back-button" text="←" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>

      <VBox alignment="CENTER" layoutX="174.0" layoutY="75.0" prefHeight="360.0" prefWidth="336.0" spacing="20.0" styleClass="login-box" AnchorPane.bottomAnchor="65.0" AnchorPane.leftAnchor="174.0" AnchorPane.rightAnchor="190.0" AnchorPane.topAnchor="75.0">
         <children>
            <Label styleClass="login-title" text="Login">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>

            <TextField fx:id="emailField" promptText="Email Address" styleClass="text-field">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </TextField>

            <PasswordField fx:id="passwordField" promptText="Password" styleClass="text-field">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
            </PasswordField>

            <Button fx:id="enterButton" defaultButton="true" mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" prefWidth="280.0" styleClass="login-button" text="ENTER HITSTER">
               <VBox.margin>
                  <Insets top="15.0" />
               </VBox.margin>
            </Button>

            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Hyperlink fx:id="registerLink" onAction="#handleRegister" prefHeight="25.0" prefWidth="98.0" styleClass="hyperlink" text="Create Account" />
                  <Label text="|" textFill="#949494" />
                  <Hyperlink fx:id="forgotPasswordLink" onAction="#handleForgotPassword" prefHeight="25.0" prefWidth="112.0" styleClass="hyperlink" text="Forgot Password?" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
