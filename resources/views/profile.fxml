<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1080.0" prefWidth="1920.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hitster.client.controllers.ProfileController">
   <children>
      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" styleClass="back-button" text="←" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0" style="-fx-font-size: 50px; -fx-padding: 0;"/>
      
      <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label styleClass="hitster-title" style="-fx-font-size: 85px; -fx-letter-spacing: 12px;" text="MY PROFILE" />

            <HBox alignment="CENTER" spacing="50.0" VBox.vgrow="ALWAYS">
               <children>
                  
                  <VBox alignment="CENTER" prefWidth="650.0" spacing="30.0">
                     <children>
                        
                        <VBox alignment="CENTER" spacing="15.0" styleClass="desktop-panel">
                           <padding>
                              <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                           </padding>
                           <children>
                              <StackPane onMouseClicked="#handleUploadImage" style="-fx-cursor: hand;" styleClass="avatar-circle">
                                 <children>
                                    <ImageView fx:id="profileImageView" fitHeight="130.0" fitWidth="130.0" preserveRatio="false">
                                       <clip>
                                          <Circle centerX="65.0" centerY="65.0" radius="65.0" />
                                       </clip>
                                    </ImageView>
                                 </children>
                                 <VBox.margin>
                                    <Insets bottom="10.0" />
                                 </VBox.margin>
                              </StackPane>
                              
                              <HBox alignment="CENTER" spacing="15.0">
                                 <children>
                                    <Label fx:id="usernameLabel" styleClass="profile-text-main" text="Alice" />
                                    <Button mnemonicParsing="false" onAction="#handleEditUsername" styleClass="edit-btn" text="✎" />
                                 </children>
                              </HBox>
                              
                              <HBox alignment="CENTER" spacing="15.0">
                                 <children>
                                    <Label fx:id="emailLabel" styleClass="profile-text-sub" text="User@gmail.com" />
                                    <Button mnemonicParsing="false" onAction="#handleEditEmail" styleClass="edit-btn" text="✎" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="20.0" styleClass="desktop-panel">
                           <padding>
                              <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                           </padding>
                           <children>
                              <Label style="-fx-font-size: 35px; -fx-letter-spacing: 3px;" styleClass="subtitle" text="STATISTICS" />
                              <HBox alignment="CENTER" spacing="70.0">
                                 <children>
                                    <VBox alignment="CENTER" spacing="10.0">
                                       <children>
                                          <StackPane styleClass="stat-circle">
                                             <children>
                                                <Label fx:id="totalWinsLabel" styleClass="stat-value" text="160" />
                                             </children>
                                          </StackPane>
                                          <Label style="-fx-font-size: 24px;" styleClass="profile-text-sub" text="Total Wins" />
                                       </children>
                                    </VBox>
                                    <VBox alignment="CENTER" spacing="10.0">
                                       <children>
                                          <StackPane styleClass="stat-circle">
                                             <children>
                                                <Label fx:id="winRateLabel" styleClass="stat-value" text="68%" />
                                             </children>
                                          </StackPane>
                                          <Label style="-fx-font-size: 24px;" styleClass="profile-text-sub" text="Win Rate" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <VBox alignment="CENTER" prefWidth="850.0" spacing="25.0">
                     <children>
                        <VBox alignment="CENTER" spacing="20.0" styleClass="desktop-panel" VBox.vgrow="ALWAYS">
                           <padding>
                              <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                           </padding>
                           <children>
                              <Label style="-fx-font-size: 35px; -fx-letter-spacing: 3px;" styleClass="subtitle" text="MATCH HISTORY" />
                              <TableView fx:id="matchHistoryTable" styleClass="glow-table" VBox.vgrow="ALWAYS">
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                                <columns>
                                  <TableColumn fx:id="opponentCol" prefWidth="280.0" text="PLAYER" />
                                  <TableColumn fx:id="dateCol" prefWidth="230.0" text="DATE" />
                                    <TableColumn fx:id="resultCol" prefWidth="230.0" text="RESULT" />
                                </columns>
                              </TableView>
                           </children>
                        </VBox>
                        
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeleteAccount" prefHeight="70.0" styleClass="danger-button" text="DELETE ACCOUNT" />
                     </children>
                  </VBox>
                  
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>